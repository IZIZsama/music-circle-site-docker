generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  studentId     String    @unique
  email         String    @unique
  passwordHash  String
  iconPath      String
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  instruments   String    // JSON: ["Vo","Gt"] など
  bands         UserBand[]
  reservations  Reservation[]
  circleFees    CircleFeeStatus[]
  passwordReset PasswordReset?
}

model UserBand {
  userId  String
  bandId  String
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  band    Band @relation(fields: [bandId], references: [id], onDelete: Cascade)
  @@id([userId, bandId])
}

model Band {
  id            String       @id @default(cuid())
  name          String
  createdAt     DateTime     @default(now())
  users         UserBand[]
  reservations  Reservation[]
}

model Reservation {
  id        String    @id @default(cuid())
  startAt   DateTime
  endAt     DateTime
  location  String    // ROOM_802_FRONT | ROOM_802_PERSONAL | STUDIO
  bandId    String?
  memo      String?
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  band      Band?  @relation(fields: [bandId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  @@index([startAt, endAt, location])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CircleFeeStatus {
  id         String   @id @default(cuid())
  userId     String
  fiscalYear Int
  springPaid Boolean  @default(false)
  autumnPaid Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fiscalYear])
  @@index([fiscalYear])
}
