PORT=3001
CLIENT_ORIGIN=http://localhost:5173
SESSION_SECRET=your-secret-key-change-in-production
# Prisma (MySQL)
DATABASE_URL=mysql://root:bandpractice@localhost:3306/band_practice
# メール（未設定なら認証コードはターミナルに表示）
# Gmail: 二段階認証を有効 → https://myaccount.google.com/apppasswords でアプリパスワード発行
# MAIL_FROM=あなたのGmailアドレス
# MAIL_APP_PASSWORD=発行した16文字（記号含めてそのまま）
# または SMTP_URL=smtp://user:pass@smtp.gmail.com:587 でも可
# MySQL（任意の直接接続設定。通常は DATABASE_URL を使う）
# MYSQLHOST=localhost
# MYSQLUSER=root
# MYSQLPASSWORD=your-password
# MYSQLDATABASE=your-database
# MYSQLPORT=3306
